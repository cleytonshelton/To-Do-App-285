<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
  <title>Edit Work Item - Todo App</title>
  <style>
    body { background-color: #f4f7f9; font-family: 'Inter', sans-serif; }
    .custom-card { border: 1px solid #dfe1e5; border-radius: 4px; }
    .subtask-item { background: #f8f9fa; border: 1px solid #e9ecef; border-radius: 4px; margin-bottom: 5px; padding: 8px 12px; display: flex; align-items: center; justify-content: space-between; }
  </style>
</head>

<body>
  <%- include('./partials/nav.ejs') %>

  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <h4 class="mb-4"><strong>Edit Work Item #<%= data._id.toString().slice(-5) %></strong></h4>

        <div class="card custom-card">
          <div class="card-body">
            <form action="/edit?_method=PUT" method="POST">
              <input value="<%= data._id %>" name="id" type="hidden">

              <div class="form-group">
                <label class="font-weight-600">Title</label>
                <input type="text" class="form-control" name="title" value="<%= data.title %>" required />
              </div>

              <div class="row">
                <div class="col-md-4">
                  <div class="form-group">
                    <label class="font-weight-600">Status</label>
                    <select class="form-control" name="status">
                      <option value="Pending" <%= data.status === 'Pending' ? 'selected' : '' %>>To Do</option>
                      <option value="In Progress" <%= data.status === 'In Progress' ? 'selected' : '' %>>In Progress</option>
                      <option value="Completed" <%= data.status === 'Completed' ? 'selected' : '' %>>Done</option>
                    </select>
                  </div>
                </div>

                <div class="col-md-4">
                  <div class="form-group">
                    <label class="font-weight-600">Priority</label>
                    <select class="form-control" name="priority">
                      <option value="1" <%= data.priority == 1 ? 'selected' : '' %>>1 - Critical</option>
                      <option value="2" <%= data.priority == 2 ? 'selected' : '' %>>2 - High</option>
                      <option value="3" <%= data.priority == 3 ? 'selected' : '' %>>3 - Medium</option>
                      <option value="4" <%= data.priority == 4 ? 'selected' : '' %>>4 - Low</option>
                    </select>
                  </div>
                </div>

                <div class="col-md-4">
                  <div class="form-group">
                    <label class="font-weight-600">Due Date</label>
                    <% 
                      let flatDate = "";
                      if (data.date) {
                        let d = new Date(data.date);
                        d.setMinutes(d.getMinutes() - d.getTimezoneOffset());
                        flatDate = d.toISOString().slice(0, 16);
                      }
                    %>
                    <input type="datetime-local" class="form-control" name="date" value="<%= flatDate %>" />
                  </div>
                </div>
                            </div>

              <div class="form-group">
                <label class="font-weight-600">Tags (comma separated)</label>
                <input
                  type="text"
                  class="form-control"
                  name="tags"
                  value="<%= (data.tags || []).join(', ') %>"
                  placeholder="School, Work, Personal"
                />
              </div>

              <hr>

              <div class="form-group">
                <label class="font-weight-600">Subtasks (Child Items)</label>
                <div id="subtask-container">
                  <% if (data.subtasks && data.subtasks.length > 0) { %>
                    <% data.subtasks.forEach((sub, index) => { %>
                      <div class="subtask-item">
                        <div class="d-flex align-items-center flex-grow-1">
                          <input type="checkbox" name="subtasks[<%= index %>][completed]" value="true" <%= sub.completed ? 'checked' : '' %> class="mr-2">
                          <input type="text" name="subtasks[<%= index %>][title]" value="<%= sub.title %>" class="form-control form-control-sm border-0 bg-transparent">
                        </div>
                        <button type="button" class="btn btn-sm text-danger remove-subtask"><i class="fas fa-times"></i></button>
                      </div>
                    <% }) %>
                  <% } %>
                </div>
                <button type="button" id="add-subtask-btn" class="btn btn-sm btn-outline-primary mt-2">
                  <i class="fas fa-plus mr-1"></i> Add Subtask
                </button>
              </div>

              <div class="mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-primary" style="background-color: #0078d4; border: none;">Save Changes</button>
                <a href="/list" class="btn btn-link text-muted">Cancel</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
  <script>
    // FIXED: Using EJS to set the initial index from the server data
    let subtaskIndex = <%= data.subtasks ? data.subtasks.length : 0 %>;

    $('#add-subtask-btn').click(function() {
      const html = `
        <div class="subtask-item">
          <div class="d-flex align-items-center flex-grow-1">
            <input type="hidden" name="subtasks[${subtaskIndex}][completed]" value="false">
            <input type="checkbox" name="subtasks[${subtaskIndex}][completed]" value="true" class="mr-2">
            <input type="text" name="subtasks[${subtaskIndex}][title]" placeholder="New subtask..." class="form-control form-control-sm" required>
          </div>
          <button type="button" class="btn btn-sm text-danger remove-subtask"><i class="fas fa-times"></i></button>
        </div>
      `;
      $('#subtask-container').append(html);
      subtaskIndex++;
    });

    $(document).on('click', '.remove-subtask', function() {
      $(this).closest('.subtask-item').remove();
    });
  </script>
</body>

</html>