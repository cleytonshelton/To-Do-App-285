<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

  <title>Home - Todo App</title>
  
  <style>
    /* 1. HOME PAGE THEME VARIABLES */
    :root {
      --bg-body: #ffffff;
      --bg-hero: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%);
      --text-main: #1a1a1b;
      --text-muted: #6c757d;
      --card-bg: #ffffff;
      --border-color: #dee2e6;
      --feature-icon-bg: #e2e8f0;
    }

    [data-theme='dark'] {
      --bg-body: #121212;
      --bg-hero: linear-gradient(135deg, #121212 0%, #1e293b 100%);
      --text-main: #f8fafc;
      --text-muted: #94a3b8;
      --card-bg: #1e1e1e;
      --border-color: #334155;
      --feature-icon-bg: #334155;
    }

    /* 🌊 OCEAN THEME */
    [data-theme='ocean'] {
      --bg-body: #f0f9ff;
      --bg-hero: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
      --text-main: #0c4a6e;
      --text-muted: #0284c7;
      --card-bg: #ffffff;
      --border-color: #bae6fd;
      --feature-icon-bg: #bae6fd;
    }

    /* 🌌 MIDNIGHT THEME */
    [data-theme='midnight'] {
      --bg-body: #0f172a;
      --bg-hero: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      --text-main: #f8fafc;
      --text-muted: #94a3b8;
      --card-bg: #1e293b;
      --border-color: #334155;
      --feature-icon-bg: #334155;
    }

    /* 🌲 FOREST THEME */
    [data-theme='forest'] {
      --bg-body: #f0fdf4;
      --bg-hero: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
      --text-main: #14532d;
      --text-muted: #16a34a;
      --card-bg: #ffffff;
      --border-color: #bbf7d0;
      --feature-icon-bg: #bbf7d0;
    }

    /* 🌅 SUNSET THEME */
    [data-theme='sunset'] {
      --bg-body: #fff1f2;
      --bg-hero: linear-gradient(135deg, #fff1f2 0%, #ffe4e6 100%);
      --text-main: #881337;
      --text-muted: #e11d48;
      --card-bg: #ffffff;
      --border-color: #fecdd3;
      --feature-icon-bg: #fecdd3;
    }

    /* 🤖 CYBERPUNK THEME */
    [data-theme='cyberpunk'] {
      --bg-body: #09090b;
      --bg-hero: linear-gradient(135deg, #09090b 0%, #18181b 100%);
      --text-main: #fdf5ff;
      --text-muted: #a1a1aa;
      --card-bg: #18181b;
      --border-color: #27272a;
      --feature-icon-bg: #27272a;
    }

    /* ☕ COFFEE THEME */
    [data-theme='coffee'] {
      --bg-body: #fdf8f6;
      --bg-hero: linear-gradient(135deg, #fdf8f6 0%, #f5ebe6 100%);
      --text-main: #4a3b32;
      --text-muted: #8a6d5b;
      --card-bg: #ffffff;
      --border-color: #e7d5c9;
      --feature-icon-bg: #e7d5c9;
    }

    /* 2. APPLYING VARIABLES */
    body {
      background-color: var(--bg-body);
      color: var(--text-main);
      font-family: 'Inter', sans-serif;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    .hero-section {
      padding: 100px 0;
      background: var(--bg-hero);
      transition: background 0.3s ease;
    }

    .card {
      background-color: var(--card-bg);
      border-color: var(--border-color) !important;
      transition: background-color 0.3s ease, border-color 0.3s ease;
    }

    .feature-icon {
      width: 48px;
      height: 48px;
      background: var(--feature-icon-bg);
      color: var(--btn-primary-bg, #0078d4);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      transition: background-color 0.3s ease, color 0.3s ease;
    }

    .text-muted { color: var(--text-muted) !important; }
    .border-top, .border-bottom { border-color: var(--border-color) !important; }

    .btn-modern {
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.2s;
    }
    .btn-modern:hover {
        transform: translateY(-2px);
    }

    /* Custom Theme Text Color for 'Seamlessly' */
    .theme-text-primary {
        color: var(--btn-primary-bg, #0078d4) !important;
        transition: color 0.3s ease;
    }
  </style>

  <script>
    (function() {
      const savedTheme = localStorage.getItem('user-theme') || 'light';
      document.documentElement.setAttribute('data-theme', savedTheme);
    })();
  </script>
</head>

<body>
  <%- include('./partials/nav.ejs') %>

  <header class="hero-section border-bottom">
    <div class="container text-center">
      <h1 class="display-4 font-weight-bold mb-3" style="letter-spacing: -1.5px;">
        Manage your day, <span class="theme-text-primary">seamlessly.</span>
      </h1>
      <p class="lead text-muted mb-5 mx-auto" style="max-width: 600px;">
        A high-performance Todo application built with secure authentication and flexible storage. 
        Track your progress and stay organized with ease.
      </p>
      
      <div class="d-flex justify-content-center gap-3">
        <% if (user) { %>
          <a href="/list" class="btn btn-modern btn-primary-modern px-5 shadow-sm mr-3">
            View My Tasks
          </a>
          <a href="/write" class="btn btn-modern btn-outline-primary px-5">
            + Add Task
          </a>
        <% } else { %>
          <a href="/signup" class="btn btn-modern btn-primary-modern px-5 shadow-sm mr-3">
            Get Started Free
          </a>
          <a href="/login" class="btn btn-modern btn-outline-primary px-5">
            Login
          </a>
        <% } %>
      </div>
    </div>
  </header>

  <main class="container py-5">
    <div class="row">
      <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
          <div class="card-body">
            <div class="feature-icon">
              <i class="fas fa-lock"></i>
            </div>
            <h5 class="font-weight-bold">Secure Access</h5>
            <p class="text-muted small">Your data is protected by JWT-based authentication, ensuring only you can access your personal task list.</p>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
          <div class="card-body">
            <div class="feature-icon" style="background: var(--feature-icon-bg); color: #166534;">
              <i class="fas fa-tasks"></i>
            </div>
            <h5 class="font-weight-bold">Task Management</h5>
            <p class="text-muted small">Organize tasks with priorities, due dates, and child work items for maximum productivity.</p>
          </div>
        </div>
      </div>

      <div class="col-md-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
          <div class="card-body">
            <div class="feature-icon" style="background: var(--feature-icon-bg); color: #854d0e;">
              <i class="fas fa-chart-line"></i>
            </div>
            <h5 class="font-weight-bold">Responsive Dashboard</h5>
            <p class="text-muted small">A clean, dashboard view that helps you visualize your progress month-by-month.</p>
          </div>
        </div>
      </div>
    </div>
  </main>

  <footer class="text-center py-4 text-muted border-top mt-5">
    <small>&copy; 2026 Todo App - Built with Express & ORDB</small>
  </footer>

  <script src="https://code.jquery.com/jquery-3.4.1.slim.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
</body>

</html>