<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />

  <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

  <title>Task Dashboard - Todo App</title>
</head>

<body>
  <%- include('nav.ejs') %>

  <div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
      <div>
        <h2 class="font-weight-bold mb-0">My Workspace</h2>
        <p class="text-muted">You have <%= posts.length %> active tasks</p>
      </div>
      <a href="/write" class="btn btn-modern btn-primary-modern px-4 shadow-sm">+ New Task</a>
    </div>

    <div class="row">
      <% for (var i=0; i < posts.length; i++){ %>
        <div class="col-md-6 col-lg-4 mb-4 task-item">
          <div class="card custom-card task-card-module">
            <div class="card-body p-4">
              <div class="mb-3">
                <span class="status-badge status-<%= posts[i].status || 'pending' %> mb-2">
                  <%= posts[i].status || 'pending' %>
                </span>
                <a href="/detail/<%= posts[i]._id %>" class="h5 d-block font-weight-bold text-dark text-decoration-none mt-2">
                  <%= posts[i].title %>
                </a>
              </div>
              
              <p class="text-muted small mb-0">
                <i class="far fa-calendar-alt mr-1"></i> <%= posts[i].date || 'No date set' %>
              </p>

              <div class="task-footer">
                <a href="/edit/<%= posts[i]._id %>" class="btn btn-sm btn-light font-weight-600 text-primary">Edit</a>
                <button class="delete btn btn-sm btn-outline-danger border-0" data-id="<%= posts[i]._id %>">
                  <i class="fas fa-trash"></i> Delete
                </button>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
  <script>
    $('.delete').click(function (e) {
      // Small logic fix to handle button click vs icon click
      var id = $(this).data('id') || $(this).closest('button').data('id');
      var cardWrapper = $(this).closest('.task-item');

      if(confirm('Delete this task?')) {
        $.ajax({
          method: 'DELETE',
          url: '/delete',
          data: { _id: id }
        }).done((res) => {
          cardWrapper.fadeOut(400, function() {
            $(this).remove();
          });
        }).fail((xhr, code, err) => {
          alert('Delete failed');
        });
      }
    });
  </script>

  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.4.1/js/bootstrap.min.js"></script>
</body>

</html>