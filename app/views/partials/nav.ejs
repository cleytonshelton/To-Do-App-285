<script>
  (function initTheme() {
    let theme = localStorage.getItem('user-theme');

    // 1. Check if the backend passed a logged-in user object with a saved theme
    <% if (typeof user !== 'undefined' && user && user.preferences && user.preferences.theme) { %>
      const dbTheme = '<%= user.preferences.theme %>';
      
      // 2. If the browser doesn't match the database (e.g., they just logged in), trust the database!
      if (theme !== dbTheme) {
        theme = dbTheme;
        localStorage.setItem('user-theme', dbTheme);
      }
    <% } %>

    // 3. Fallback to light if absolutely nothing is set
    if (!theme) {
      theme = 'light';
    }
    
    document.documentElement.setAttribute('data-theme', theme);
  })();
</script>

