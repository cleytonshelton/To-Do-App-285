<script>
  async function changeTheme(theme) {
    // 1. Immediately update UI
    document.documentElement.setAttribute('data-theme', theme);
    localStorage.setItem('user-theme', theme);

    // 2. Save preference to the Database
    try {
      const res = await fetch('/api/settings/theme', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ theme })
      });
      if (!res.ok) console.warn('Failed to sync theme with DB');
    } catch (err) {
      console.error('Network error saving theme:', err);
    }
  }

  // FIXED: Stop the link, clear storage, then redirect manually
  function clearTheme(e) {
    e.preventDefault(); // Stop the immediate navigation
    
    // Clear everything
    localStorage.removeItem('user-theme');
    document.documentElement.setAttribute('data-theme', 'light');
    
    // Manually send them to the logout route
    window.location.href = '/logout';
  }
</script>